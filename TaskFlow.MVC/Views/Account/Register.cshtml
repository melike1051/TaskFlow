@model TaskFlow.MVC.Models.Auth.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<section class="auth-shell">
    <div class="panel-card auth-card">
        <div class="section-heading">
            <span class="eyebrow">Create account</span>
            <h1>Start managing work with clarity</h1>
            <p>Register once and move into a cleaner, more focused task flow.</p>
        </div>

        <form asp-action="Register" method="post" class="stack-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="form-row">
                <label asp-for="Username"></label>
                <input asp-for="Username" class="form-control" placeholder="Choose a username" />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="form-row">
                <label asp-for="Password"></label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Choose a strong password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="button-link button-link--primary button-submit">Create Account</button>
        </form>

        <p class="form-footnote">
            Already registered?
            <a asp-controller="Account" asp-action="Login">Sign in</a>.
        </p>
    </div>
</section>
