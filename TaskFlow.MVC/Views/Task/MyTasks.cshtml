@model List<TaskFlow.MVC.Models.Tasks.TaskViewModel>

<h2>My Tasks</h2>

<a asp-action="Create">➕ Create New Task</a>

@if (!Model.Any())
{
    <p>No tasks found.</p>
}
else
{
    <table border="1" cellpadding="5">
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Due Date</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var task in Model)
        {
            <tr>
                <td>@task.Title</td>
                <td>@task.Description</td>
                <td>@task.DueDate.ToShortDateString()</td>
                <td>@task.StatusText</td>
                <td>
                    <!-- ✏️ EDIT -->
                    <a asp-action="Edit"
                       asp-route-id="@task.Id"
                       asp-route-title="@task.Title"
                       asp-route-description="@task.Description"
                       asp-route-dueDate="@task.DueDate"
                       asp-route-status="@task.Status">
                        Edit
                    </a>

                    |

                    <!-- 🗑 DELETE -->
                    <form asp-action="Delete"
                          asp-route-id="@task.Id"
                          method="post"
                          style="display:inline"
                          onsubmit="return confirm('Are you sure you want to delete this task?');">
                        <button type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
