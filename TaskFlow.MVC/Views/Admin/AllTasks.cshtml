@model List<TaskFlow.MVC.Models.Tasks.TaskViewModel>

<h2>All Tasks (Admin)</h2>

@if (!Model.Any())
{
    <p>No tasks found.</p>
}
else
{
    <table border="1" cellpadding="5">
        <thead>
            <tr>
                <th>User</th>
                <th>Title</th>
                <th>Description</th>
                <th>Due Date</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var task in Model)
        {
            <tr>
                <td><strong>@task.Username</strong></td>
                <td>@task.Title</td>
                <td>@task.Description</td>
                <td>@task.DueDate.ToShortDateString()</td>
                <td>@task.StatusText</td>
                <td>
                    <!-- 🗑 ADMIN DELETE -->
                    <form asp-controller="Task"
                          asp-action="Delete"
                          asp-route-id="@task.Id"
                          method="post"
                          style="display:inline"
                          onsubmit="return confirm('Are you sure you want to delete this task?');">
                        <button type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
