@{
    var token = Context.Session.GetString("JWT");
    var role = Context.Session.GetString("Role");
}

<nav class="topbar">
    <div class="topbar__brand">
        <a asp-controller="Home" asp-action="Index" class="brand-mark">TaskFlow</a>
        <span class="brand-copy">Focused task execution for calm teams.</span>
    </div>

    <div class="topbar__links">
    @if (token == null)
    {
        <a asp-controller="Account" asp-action="Login">Login</a>
        <a asp-controller="Account" asp-action="Register" class="button-link button-link--primary">Register</a>
    }
    else
    {
        <a asp-controller="Task" asp-action="MyTasks">My Tasks</a>
        <a asp-controller="Task" asp-action="Create">Create Task</a>

        @if (role == "Admin")
        {
            <a asp-controller="Admin" asp-action="AllTasks">All Tasks</a>
            <a asp-controller="Admin" asp-action="Users">Users</a>
        }

        <a asp-controller="Account" asp-action="Logout" class="button-link">Logout</a>
    }
    </div>
</nav>
